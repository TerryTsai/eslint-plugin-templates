{
  "name": "eslint-plugin-templates",
  "version": "0.1.0",
  "description": "ESLint plugin that enforces structural conformance of files against declarative templates.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "templates",
    "structural-linting",
    "ast"
  ],
  "author": "Terry Tsai <ttsai0509@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TerryTsai/eslint-plugin-templates.git"
  },
  "bugs": {
    "url": "https://github.com/TerryTsai/eslint-plugin-templates/issues"
  },
  "homepage": "https://github.com/TerryTsai/eslint-plugin-templates#readme",
  "peerDependencies": {
    "eslint": ">=8"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
